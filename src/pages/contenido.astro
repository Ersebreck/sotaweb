---
import Layout from '../layouts/Layout.astro';

const areas = [
  {
    titulo: 'Lectura crítica',
    descripcion: 'Comprensión lectora, análisis de textos, argumentación y pensamiento crítico. Herramientas para leer el mundo.',
    icono: '📖',
    tipo: null,
    url: null,
  },
  {
    titulo: 'Matemáticas',
    descripcion: 'Razonamiento cuantitativo, álgebra, geometría y estadística. Desde los fundamentos hasta los ejercicios de la prueba.',
    icono: '∑',
    tipo: null,
    url: null,
  },
  {
    titulo: 'Ciencias naturales',
    descripcion: 'Biología, química y física: conceptos clave, resolución de problemas y comprensión del entorno natural.',
    icono: '⚗',
    tipo: null,
    url: null,
  },
  {
    titulo: 'Ciencias sociales',
    descripcion: 'Historia, geografía, economía y política. Una lectura crítica del pasado y del presente.',
    icono: '🌎',
    tipo: null,
    url: null,
  },
  {
    titulo: 'Inglés',
    descripcion: 'Comprensión de lectura en inglés, vocabulario y estructuras gramaticales básicas para la prueba.',
    icono: 'Aa',
    tipo: null,
    url: null,
  },
  {
    titulo: 'Competencias ciudadanas',
    descripcion: 'Convivencia, participación, pluralidad y derechos. La ciudadanía como ejercicio político cotidiano.',
    icono: '⚖',
    tipo: null,
    url: null,
  },
];
---

<Layout
  title="Contenido — Sotavento"
  description="Material de estudio para las Pruebas Saber 11, organizado por áreas. Gratuito y construido colectivamente."
>

  <!-- Header -->
  <section class="relative overflow-hidden min-h-[50vh] flex items-end">
    <div
      id="contenido-hero-bg"
      class="absolute inset-0 bg-cover bg-center"
    ></div>
    <script>
      const imgs = ['/sotaweb/images/cientificas.png', '/sotaweb/images/poetas.png', '/sotaweb/images/ingenierxs.png', '/sotaweb/images/sociologx.png'];
      const pick = imgs[Math.floor(Math.random() * imgs.length)];
      document.getElementById('contenido-hero-bg').style.backgroundImage = `url('${pick}')`;
    </script>
    <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/65 to-dark/20"></div>

    <div class="relative max-w-5xl mx-auto px-6 pb-16 pt-32 w-full">
      <p class="label-jacatra mb-4">Contenido</p>
      <h1 class="font-display text-5xl md:text-7xl font-semibold text-cream-light leading-tight mb-4 max-w-xl">
        Material de<br /><em class="not-italic text-olive">estudio</em>
      </h1>
      <div class="w-16 h-0.5 bg-olive"></div>
    </div>
  </section>

  <!-- Intro -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <p class="text-lg text-dark-muted leading-relaxed max-w-3xl">
      Acá encontrás el material que los profes voluntarixs de Sotavento van construyendo
      para cada área del ICFES. Todo es gratuito y de acceso libre.
      El contenido se actualiza cada semestre junto al proceso.
    </p>
  </section>

  <div class="max-w-5xl mx-auto px-6">
    <div class="h-px bg-olive/25"></div>
  </div>

  <!-- Areas grid -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <p class="label-jacatra mb-4">Areas</p>
    <h2 class="font-display text-4xl font-semibold text-dark mb-12 leading-tight">
      Seis áreas, un mismo proceso
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {areas.map((area) => (
        <div class={`group relative flex flex-col border rounded-sm p-7 transition-colors ${
          area.url
            ? 'border-olive/25 hover:border-olive bg-cream-light hover:bg-cream cursor-pointer'
            : 'border-olive/15 bg-cream-light'
        }`}>

          <!-- Icon -->
          <div class="w-12 h-12 rounded-sm bg-olive/10 border border-olive/20 flex items-center justify-center mb-5 text-xl font-display font-semibold text-olive">
            {area.icono}
          </div>

          <!-- Title + description -->
          <h3 class="font-display text-xl font-semibold text-dark mb-2 leading-snug">
            {area.titulo}
          </h3>
          <p class="text-sm text-dark-muted leading-relaxed flex-1">
            {area.descripcion}
          </p>

          <!-- Link or "próximamente" -->
          <div class="mt-6">
            {area.url ? (
              <a
                href={area.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm font-medium text-olive hover:text-olive-dark transition-colors"
              >
                {area.tipo === 'notebooklm' ? 'Abrir en NotebookLM' : 'Ver material'}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            ) : (
              <span class="inline-flex items-center gap-2 text-xs font-medium text-dark-muted/60 border border-dashed border-dark/15 rounded-sm px-3 py-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-olive/40 inline-block"></span>
                Próximamente
              </span>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Nota colaborativa -->
  <section class="bg-dark py-16 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-40 h-40 rounded-full border border-cream/5 translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>

    <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row gap-10 items-start md:items-center">
      <div class="flex-1">
        <p class="label-jacatra mb-3">Suma tu saber</p>
        <h2 class="font-display text-3xl font-semibold text-cream-light mb-3 leading-tight">
          ¿Tenés material que pueda servir?
        </h2>
        <p class="text-cream/65 leading-relaxed text-sm">
          El contenido de Sotavento lo construimos entre todxs.
          Si sos voluntarix o estudiante y querés aportar material, escribinos.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 flex-shrink-0">
        <a
          href="https://instagram.com/sotaventopopular"
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 bg-olive text-cream-light text-sm font-medium rounded-sm hover:bg-olive-dark transition-colors text-center"
        >
          @sotaventopopular
        </a>
        <a
          href="/sotaweb/voluntarixs"
          class="px-6 py-3 border border-cream/20 text-cream text-sm font-medium rounded-sm hover:border-olive hover:text-olive transition-colors text-center"
        >
          Ser voluntarix
        </a>
      </div>
    </div>
  </section>

</Layout>
