---
const navLinks = [
  { href: '/sotaweb/', label: 'Inicio' },
  { href: '/sotaweb/quienes-somos', label: 'Quiénes somos' },
  { href: '/sotaweb/contenido', label: 'Contenido' },
  { href: '/sotaweb/voluntarixs', label: 'Voluntarixs' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur-sm border-b border-olive/20">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/sotaweb/" class="flex items-center gap-3 group">
      <div class="w-8 h-8 rounded-full border-2 border-olive flex items-center justify-center">
        <div class="w-3 h-3 rounded-full bg-olive"></div>
      </div>
      <span class="font-display text-xl font-semibold text-dark leading-none">
        Sotavento
      </span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`text-sm font-medium transition-colors hover:text-olive ${
              currentPath === href ? 'text-olive border-b border-olive pb-0.5' : 'text-dark-muted'
            }`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 text-dark"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-olive/20 bg-cream">
    <ul class="max-w-5xl mx-auto px-6 py-4 flex flex-col gap-4">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`block text-sm font-medium transition-colors hover:text-olive ${
              currentPath === href ? 'text-olive' : 'text-dark-muted'
            }`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
