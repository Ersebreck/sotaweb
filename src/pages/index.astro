---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pre-ICFES Sotavento — Popular y Comunitario">

  <!-- Hero -->
  <section class="relative overflow-hidden min-h-[90vh] flex items-center">

    <!-- Geometric decorations -->
    <div class="absolute top-8 right-8 w-24 h-24 rounded-full border-2 border-dark/15 pointer-events-none"></div>
    <div class="absolute top-16 right-16 w-10 h-10 rounded-full bg-olive/20 pointer-events-none"></div>
    <div class="absolute bottom-16 left-6 w-40 h-40 rounded-full bg-olive/15 pointer-events-none"></div>
    <div class="absolute bottom-8 left-8 w-16 h-16 rounded-full bg-cream border-2 border-olive/30 pointer-events-none"></div>
    <div class="absolute top-1/3 right-0 w-32 h-32 rounded-full border-2 border-dark/10 translate-x-1/2 pointer-events-none"></div>

    <div class="max-w-5xl mx-auto px-6 py-24 w-full">
      <div class="max-w-2xl">
        <p class="text-sm font-medium uppercase tracking-widest text-olive mb-6">
          Ciudad Bolívar · Bosa · Bogotá
        </p>
        <h1 class="font-display text-6xl md:text-8xl font-semibold leading-[1.05] text-dark mb-6">
          Pre-ICFES<br />
          <em class="not-italic text-olive">Popular</em><br />
          y Comunitario
        </h1>
        <div class="w-16 h-0.5 bg-olive mb-8"></div>
        <p class="text-lg text-dark-muted leading-relaxed mb-10 max-w-lg">
          Espacio gratuito de preparación para el ICFES desde la educación popular.
          Un proceso construido colectivamente por y para los barrios del sur de Bogotá.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/quienes-somos"
            class="px-6 py-3 bg-dark text-cream-light text-sm font-medium rounded-sm hover:bg-olive transition-colors"
          >
            Conoce el proceso
          </a>
          <a
            href="/voluntarixs"
            class="px-6 py-3 border border-dark text-dark text-sm font-medium rounded-sm hover:border-olive hover:text-olive transition-colors"
          >
            Quiero sumarme
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-5xl mx-auto px-6">
    <div class="h-px bg-olive/25"></div>
  </div>

  <!-- Qué es -->
  <section class="max-w-5xl mx-auto px-6 py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-olive mb-4">¿Qué es?</p>
        <h2 class="font-display text-4xl md:text-5xl font-semibold text-dark leading-tight mb-6">
          Una escuela que nace desde abajo
        </h2>
        <div class="w-10 h-0.5 bg-olive mb-6"></div>
      </div>
      <div class="space-y-5 text-dark-muted leading-relaxed">
        <p>
          El Pre-ICFES Sotavento es un espacio de preparación gratuito para estudiantes de grado 11
          que quieren presentar las Pruebas Saber 11. No es una academia, es un proceso comunitario.
        </p>
        <p>
          Nace del <strong class="text-dark font-medium">Parche de Investigación Popular Sotavento</strong>,
          ligado a Aguante Popular, con años de trabajo en educación popular en Ciudad Bolívar.
          En 2024 abrimos una segunda sede en Bosa.
        </p>
        <p>
          Aquí los saberes se comparten entre pares. Las y los educadores son voluntarixs
          que entienden la docencia como praxis política y la educación como herramienta de transformación.
        </p>
      </div>
    </div>
  </section>

  <!-- Sedes -->
  <section class="bg-dark text-cream py-20 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-64 h-64 rounded-full border border-cream/10 translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-40 h-40 rounded-full bg-olive/20 -translate-x-1/4 translate-y-1/4 pointer-events-none"></div>

    <div class="max-w-5xl mx-auto px-6 relative">
      <p class="text-xs font-semibold uppercase tracking-widest text-olive mb-4">Dónde estamos</p>
      <h2 class="font-display text-4xl md:text-5xl font-semibold text-cream-light leading-tight mb-12">
        Dos sedes, un mismo proceso
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border border-cream/15 p-8 rounded-sm hover:border-olive/60 transition-colors">
          <div class="w-8 h-8 rounded-full bg-olive/30 border border-olive mb-6 flex items-center justify-center">
            <div class="w-3 h-3 rounded-full bg-olive"></div>
          </div>
          <h3 class="font-display text-2xl font-semibold text-cream-light mb-2">Ciudad Bolívar</h3>
          <p class="text-cream/60 text-sm leading-relaxed">
            Donde nació el proceso en 2017. Barrios del sur de Bogotá,
            territorio de resistencia y memoria popular.
          </p>
        </div>

        <div class="border border-cream/15 p-8 rounded-sm hover:border-olive/60 transition-colors">
          <div class="w-8 h-8 rounded-full bg-olive/30 border border-olive mb-6 flex items-center justify-center">
            <div class="w-3 h-3 rounded-full bg-olive"></div>
          </div>
          <h3 class="font-display text-2xl font-semibold text-cream-light mb-2">Bosa</h3>
          <p class="text-cream/60 text-sm leading-relaxed">
            Nueva sede desde 2024. El proceso crece y se expande
            hacia otros barrios populares del sur de la ciudad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Voluntarixs -->
  <section class="max-w-5xl mx-auto px-6 py-24 text-center relative">
    <div class="absolute left-0 top-1/2 w-24 h-24 rounded-full border-2 border-olive/20 -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>

    <p class="text-xs font-semibold uppercase tracking-widest text-olive mb-4">Súmate</p>
    <h2 class="font-display text-4xl md:text-5xl font-semibold text-dark mb-6 max-w-xl mx-auto leading-tight">
      ¿Querés ser parte del proceso?
    </h2>
    <p class="text-dark-muted mb-10 max-w-md mx-auto leading-relaxed">
      Si te identificás con la educación popular y querés compartir tus saberes
      con estudiantes del sur de Bogotá, hay un lugar para vos.
    </p>
    <a
      href="/voluntarixs"
      class="inline-block px-8 py-3.5 bg-olive text-cream-light text-sm font-medium rounded-sm hover:bg-olive-dark transition-colors"
    >
      Ver cómo unirme
    </a>
  </section>

</Layout>
