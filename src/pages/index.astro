---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pre-ICFES Sotavento — Popular y Comunitario">

  <!-- Hero: Ciudad Bolívar mural photo as full-bleed background -->
  <section class="relative min-h-screen flex items-end overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style="background-image: url('/sotaweb/images/hero-cb.jpg');"
    ></div>
    <!-- Gradient overlay: dark at bottom for text, lighter at top -->
    <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/70 to-dark/20"></div>

    <!-- Geometric accents -->
    <div class="absolute top-10 right-10 w-28 h-28 rounded-full border border-cream/20 pointer-events-none"></div>
    <div class="absolute top-16 right-16 w-12 h-12 rounded-full bg-olive/30 pointer-events-none"></div>

    <div class="relative max-w-5xl mx-auto px-6 pb-20 pt-32 w-full">
      <p class="text-xs font-semibold uppercase tracking-widest text-olive mb-5">
        Ciudad Bolívar · Bosa · Bogotá
      </p>
      <h1 class="font-display text-6xl md:text-8xl font-semibold leading-[1.05] text-cream-light mb-6">
        Pre-ICFES<br />
        <em class="not-italic text-olive">Popular</em><br />
        y Comunitario
      </h1>
      <div class="w-16 h-0.5 bg-olive mb-8"></div>
      <p class="text-lg text-cream/75 leading-relaxed mb-10 max-w-lg">
        Espacio gratuito de preparación para las Pruebas Saber 11, construido
        colectivamente desde la educación popular en los barrios del sur de Bogotá.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="/sotaweb/quienes-somos"
          class="px-6 py-3 bg-olive text-cream-light text-sm font-medium rounded-sm hover:bg-olive-dark transition-colors"
        >
          Conoce el proceso
        </a>
        <a
          href="/sotaweb/voluntarixs"
          class="px-6 py-3 border border-cream/40 text-cream text-sm font-medium rounded-sm hover:border-olive hover:text-olive transition-colors"
        >
          Quiero sumarme
        </a>
      </div>
    </div>
  </section>

  <!-- Qué es -->
  <section class="max-w-5xl mx-auto px-6 py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-olive mb-4">¿Qué es?</p>
        <h2 class="font-display text-4xl md:text-5xl font-semibold text-dark leading-tight mb-6">
          Una escuela que nace desde abajo
        </h2>
        <div class="w-10 h-0.5 bg-olive mb-6"></div>
        <div class="space-y-4 text-dark-muted leading-relaxed">
          <p>
            El Pre-ICFES Sotavento es un proceso comunitario y gratuito de preparación
            para las Pruebas Saber 11. No es una academia comercial —
            es un espacio construido entre compañerxs del territorio.
          </p>
          <p>
            Nace del <strong class="text-dark font-medium">Parche de Investigación Popular Sotavento</strong>,
            parte de Aguante Popular, con años de trabajo en educación popular en Ciudad Bolívar.
            En 2024 abrimos sede en Bosa.
          </p>
        </div>
      </div>

      <!-- Soviet "Knowledge for All" poster as visual element -->
      <div class="relative">
        <div class="absolute -top-4 -left-4 w-full h-full border border-olive/20 rounded-sm pointer-events-none"></div>
        <figure class="relative">
          <img
            src="/sotaweb/images/educacion.jpg"
            alt="Poster soviético: Знания — Всем! (El conocimiento, para todxs)"
            class="w-full rounded-sm object-cover grayscale mix-blend-multiply"
            style="max-height: 480px; object-position: top;"
          />
          <figcaption class="mt-3 text-xs text-dark-muted italic text-right">
            "Знания — Всем!" — El conocimiento, para todxs
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-5xl mx-auto px-6">
    <div class="h-px bg-olive/25"></div>
  </div>

  <!-- Sedes: barrio photo as background -->
  <section class="relative py-24 overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('/sotaweb/images/barrio.jpg');"
    ></div>
    <div class="absolute inset-0 bg-dark/80"></div>

    <div class="relative max-w-5xl mx-auto px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-olive mb-4">Dónde estamos</p>
      <h2 class="font-display text-4xl md:text-5xl font-semibold text-cream-light mb-12 leading-tight">
        Dos sedes, un mismo proceso
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border border-cream/15 p-8 rounded-sm hover:border-olive/60 transition-colors bg-dark/40 backdrop-blur-sm">
          <div class="w-8 h-8 rounded-full bg-olive/40 border border-olive mb-6 flex items-center justify-center">
            <div class="w-3 h-3 rounded-full bg-olive"></div>
          </div>
          <h3 class="font-display text-2xl font-semibold text-cream-light mb-2">Ciudad Bolívar</h3>
          <p class="text-cream/60 text-sm leading-relaxed">
            Donde nació el proceso en 2017. Territorio de resistencia y memoria popular
            en el sur de Bogotá.
          </p>
        </div>

        <div class="border border-cream/15 p-8 rounded-sm hover:border-olive/60 transition-colors bg-dark/40 backdrop-blur-sm">
          <div class="w-8 h-8 rounded-full bg-olive/40 border border-olive mb-6 flex items-center justify-center">
            <div class="w-3 h-3 rounded-full bg-olive"></div>
          </div>
          <h3 class="font-display text-2xl font-semibold text-cream-light mb-2">Bosa</h3>
          <p class="text-cream/60 text-sm leading-relaxed">
            Nueva sede desde 2024. El proceso crece hacia otros barrios
            populares del sur de la ciudad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Voluntarixs -->
  <section class="max-w-5xl mx-auto px-6 py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">

      <figure class="relative order-2 md:order-1">
        <img
          src="/sotaweb/images/mercado.jpg"
          alt="Barrio popular, vida comunitaria"
          class="w-full rounded-sm object-cover"
          style="max-height: 420px;"
        />
      </figure>

      <div class="order-1 md:order-2">
        <p class="text-xs font-semibold uppercase tracking-widest text-olive mb-4">Súmate</p>
        <h2 class="font-display text-4xl md:text-5xl font-semibold text-dark mb-6 leading-tight">
          ¿Querés ser parte del proceso?
        </h2>
        <div class="w-10 h-0.5 bg-olive mb-6"></div>
        <p class="text-dark-muted mb-8 leading-relaxed">
          Si te identificás con la educación popular y querés compartir tus saberes
          con estudiantes del sur de Bogotá, hay un lugar para vos.
        </p>
        <a
          href="/sotaweb/voluntarixs"
          class="inline-block px-8 py-3.5 bg-dark text-cream-light text-sm font-medium rounded-sm hover:bg-olive transition-colors"
        >
          Ver cómo unirme
        </a>
      </div>
    </div>
  </section>

</Layout>
